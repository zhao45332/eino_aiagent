# 复制为 config/.env 后填写密钥并取消注释。勿将 .env 提交到版本库。
# 在仓库根目录执行 go run 或运行 bin/aiagent 时，都会尝试加载本文件与根目录 .env。

# 方式 A：OpenAI 兼容（默认，含阿里云 DashScope 兼容、智谱等）
# 装配模式：默认 supervisor（主管分流）；faq_only = 仅单 Agent（知识库检索 + 计算器），无天气/定位子 Agent、无 transfer_to_agent
# AGENT_MODE=
# AGENT_MODE=faq_only

# MODEL_TYPE=openai
# 任选其一：OPENAI_API_KEY 或 DASHSCOPE_API_KEY（代码见 internal/config/config.go）
# OPENAI_API_KEY=
# DASHSCOPE_API_KEY=
# 不填时：若仅用 DASHSCOPE_API_KEY，会默认走智谱兼容地址；用阿里云需设置下方 BASE_URL
# OPENAI_BASE_URL=
# CHAT_MODEL=
# 对话 HTTP：整次请求超时（秒），默认 180。智谱等若报 unexpected EOF，已默认对 bigmodel.cn 禁用 HTTP/2；仍异常可设 OPENAI_HTTP_DISABLE_KEEPALIVE=1
# OPENAI_HTTP_TIMEOUT=180
# OPENAI_HTTP_DISABLE_HTTP2=1
# OPENAI_HTTP_DISABLE_KEEPALIVE=1
# 向量知识库：CS_RAG=1 与 KNOWLEDGE_BASE_ENABLED=1 等价（二选一即可），为 true 时尝试连接 Milvus 并注册 search_knowledge 工具，由模型按需检索；需 Milvus + Embedding。智谱 bigmodel 见 config 默认 embedding-2 与 1024 维。
# EMBEDDING_MODEL=
# EMBEDDING_DIM=
# EMBEDDING_BASEURL=   # 空则同 OPENAI_BASE_URL
# EMBEDDING_API_KEY=   # 空则同 OPENAI_API_KEY
# CS_RAG=1
# KNOWLEDGE_BASE_ENABLED=1
# 启动时若 data/corpus/faq.md 相对上次写入的哈希有变化，会自动删 faq-* 并重灌 Milvus（写 data/corpus/.kb_faq_state.json）。关闭自动：CS_KB_AUTO_SYNC=0
# CS_SEED=1  # 可选：强制重灌（忽略哈希）；无 faq.md 时仍可用内置默认条数灌库
# MILVUS_ADDR=localhost:19530
# MILVUS_KB_COLLECTION=cs_faq

# 高德 Web 服务 Key（get_geolocation：IP 定位 / 经纬度逆地理编码），在控制台申请「Web 服务」类型
# https://lbs.amap.com/
# AMAP_KEY=
# 或 GAODE_WEB_KEY=
# 不填用户 ip 时会访问 api.ipify.org / icanhazip.com 探测出口 IPv4；若需关闭：CS_DISABLE_PUBLIC_IP_PROBE=1

# 方式 B：火山 Ark
# MODEL_TYPE=ark
# ARK_API_KEY=
# ARK_MODEL=
# ARK_BASE_URL=
